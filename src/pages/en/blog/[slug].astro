---
import { getCollection, render } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ArticleChrome from '../../../components/ArticleChrome.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', (p) => p.data.lang === 'en' && (import.meta.env.DEV || !p.data.hidden));
  const italian = await getCollection('blog', (p) => p.data.lang === 'it' && (import.meta.env.DEV || !p.data.hidden));
  return posts.map((post) => ({
    params: { slug: post.data.translationKey },
    props: {
      post,
      hasTranslation: italian.some((e) => e.data.translationKey === post.data.translationKey),
    },
  }));
}

const { post, hasTranslation } = Astro.props;
const { Content } = await render(post);
const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base
  title={`${post.data.title} — Luigi Bifulco`}
  description={post.data.description}
  lang="en"
  altUrl={hasTranslation ? `/blog/${post.data.translationKey}/` : undefined}
  ogType="article"
  ogImage={post.data.headerImage}
  publishedTime={post.data.date}
  tags={post.data.tags}
>
  <article>
    <header class="post-header">
      <p class="meta">
        <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
        {post.data.draft && <span class="draft">draft</span>}
        {post.data.hidden && <span class="draft">hidden</span>}
      </p>
      <h1>{post.data.title}</h1>
      {post.data.description && <p class="subtitle">{post.data.description}</p>}
    </header>
    {post.data.headerImage && (
      <img class="header-img" src={post.data.headerImage} alt="" width="1200" height="630" loading="eager" />
    )}
    <Content />
    {post.data.tags.length > 0 && (
      <p class="tags">{post.data.tags.map((t) => <span>#{t}</span>)}</p>
    )}
    <p class="back"><a href="/en/">&lsaquo; All posts</a></p>
  </article>
  <ArticleChrome
    title={post.data.title}
    labelDown="Jump to the end of the article"
    labelUp="Back to the top of the article"
  />
</Base>

<style>
  .post-header {
    padding: 4rem 0 1.5rem;
  }
  .post-header h1 {
    margin: 0;
    font-size: clamp(2.1rem, 6vw, 3.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.08;
  }
  .subtitle {
    margin: 1.1rem 0 0;
    font-size: 1.25rem;
    line-height: 1.5;
    letter-spacing: -0.01em;
    color: var(--muted);
  }
  .meta {
    margin: 0 0 1.1rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--faint);
  }
  .draft {
    margin-left: 0.6rem;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
    font-size: 0.7rem;
  }
  .header-img {
    width: 100%;
    aspect-ratio: 21 / 9;
    max-height: 240px;
    object-fit: cover;
    border-radius: 16px;
    margin: 0.5rem 0 1.5rem;
  }
  .tags {
    margin-top: 3rem;
    color: var(--faint);
    font-size: 0.9rem;
  }
  .tags span { margin-right: 0.7rem; }
  .back {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
    font-size: 0.95rem;
  }
  @media (max-width: 600px) {
    .post-header { padding: 2.5rem 0 1rem; }
    .subtitle { font-size: 1.1rem; }
    .header-img {
      max-height: 140px;
      border-radius: 10px;
      margin-bottom: 1.1rem;
    }
  }
</style>
