---
import { GOATCOUNTER_CODE, SITE_NAME, DEFAULT_OG_IMAGE } from '../config';

interface Props {
  title: string;
  description?: string;
  lang: 'it' | 'en';
  /** URL of the same page in the other language, if it exists */
  altUrl?: string;
  /** 'article' for blog posts, 'website' otherwise */
  ogType?: 'website' | 'article';
  /** Path (or absolute URL) of the social/preview image */
  ogImage?: string;
  publishedTime?: Date;
  tags?: string[];
}
const {
  title,
  description = '',
  lang,
  altUrl,
  ogType = 'website',
  ogImage,
  publishedTime,
  tags = [],
} = Astro.props;
const otherLang = lang === 'it' ? 'en' : 'it';
const homeUrl = lang === 'it' ? '/' : '/en/';

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = new URL(ogImage ?? DEFAULT_OG_IMAGE, Astro.site);
const altUrlAbs = altUrl ? new URL(altUrl, Astro.site) : undefined;

const jsonLd =
  ogType === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'BlogPosting',
        headline: title,
        description,
        image: ogImageAbs.href,
        url: canonical.href,
        datePublished: publishedTime?.toISOString(),
        inLanguage: lang === 'it' ? 'it-IT' : 'en-US',
        keywords: tags.join(', '),
        author: {
          '@type': 'Person',
          name: 'Luigi Bifulco',
          jobTitle: 'Software Architect',
          url: new URL(lang === 'it' ? '/about/' : '/en/about/', Astro.site).href,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: `${SITE_NAME} — Blog`,
        description,
        url: Astro.site?.href,
        inLanguage: lang === 'it' ? 'it-IT' : 'en-US',
        author: { '@type': 'Person', name: 'Luigi Bifulco', jobTitle: 'Software Architect' },
      };
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="author" content="Luigi Bifulco" />
    <meta name="theme-color" media="(prefers-color-scheme: light)" content="#fbfbfd" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#000000" />
    <link rel="canonical" href={canonical.href} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title="Luigi Bifulco — Blog" href="/rss.xml" />
    {altUrlAbs && <link rel="alternate" hreflang={otherLang} href={altUrlAbs.href} />}
    {altUrlAbs && <link rel="alternate" hreflang={lang} href={canonical.href} />}

    <!-- Open Graph: social previews pick title, description, image and tags automatically -->
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content={lang === 'it' ? 'it_IT' : 'en_US'} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={ogImageAbs.href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {ogType === 'article' && <meta property="article:author" content="Luigi Bifulco" />}
    {tags.map((t) => <meta property="article:tag" content={t} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageAbs.href} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    {GOATCOUNTER_CODE && (
      <script
        is:inline
        data-goatcounter={`https://${GOATCOUNTER_CODE}.goatcounter.com/count`}
        async
        src="https://gc.zgo.at/count.js"
      />
    )}
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a class="site-title" href={homeUrl}>Luigi Bifulco</a>
        <span class="nav-right">
          <a class="nav-link" href={lang === 'it' ? '/' : '/en/'}>Blog</a>
          <a class="nav-link" href={lang === 'it' ? '/about/' : '/en/about/'}>About</a>
          {altUrl && <a class="lang-pill" href={altUrl}>{otherLang.toUpperCase()}</a>}
        </span>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <p class="footer-name">Luigi Bifulco <span>— Software Architect</span></p>
        <p class="footer-meta">© {new Date().getFullYear()} · <a href="/rss.xml">RSS</a></p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --bg: #fbfbfd;
    --bg-elev: #ffffff;
    --fg: #1d1d1f;
    --muted: #6e6e73;
    --faint: #86868b;
    --accent: #0071e3;
    --border: rgba(0, 0, 0, 0.09);
    --hairline: rgba(0, 0, 0, 0.12);
    --code-bg: #f5f5f7;
    --nav-bg: rgba(251, 251, 253, 0.72);
  }
  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #000000;
      --bg-elev: #161617;
      --fg: #f5f5f7;
      --muted: #a1a1a6;
      --faint: #86868b;
      --accent: #2997ff;
      --border: rgba(255, 255, 255, 0.12);
      --hairline: rgba(255, 255, 255, 0.16);
      --code-bg: #1d1d1f;
      --nav-bg: rgba(0, 0, 0, 0.65);
    }
  }

  * { box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    -webkit-text-size-adjust: 100%;
  }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI',
      Roboto, 'Helvetica Neue', sans-serif;
    line-height: 1.65;
    font-size: 17px;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  ::selection { background: var(--accent); color: #fff; }

  /* ——— nav: translucent, frosted, hairline ——— */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--nav-bg);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
  }
  .site-header nav {
    max-width: 46rem;
    margin: 0 auto;
    padding: 0.8rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .site-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    color: var(--fg);
    transition: opacity 0.25s ease;
  }
  .site-title:hover { opacity: 0.65; }
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.25s ease;
    padding: 0.4rem 0.15rem;
  }
  .nav-link:hover { color: var(--fg); text-decoration: none; }
  .lang-pill {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--fg);
    text-decoration: none;
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 0.25rem 0.8rem;
    transition: all 0.25s ease;
  }
  .lang-pill:hover {
    background: var(--fg);
    color: var(--bg);
    border-color: var(--fg);
  }

  main {
    max-width: 46rem;
    margin: 0 auto;
    padding: 0 1.5rem 6rem;
  }

  a { color: var(--accent); text-decoration: none; }
  a:hover { text-decoration: underline; }

  h1, h2, h3, h4 {
    line-height: 1.15;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  /* ——— article typography ——— */
  article {
    font-size: 1.06rem;
    line-height: 1.75;
    overflow-wrap: break-word;
  }
  article table {
    display: block;
    width: 100%;
    overflow-x: auto;
    border-collapse: collapse;
  }
  article h2, article h3, article h4 {
    margin-top: 2.75rem;
    margin-bottom: 0.75rem;
    letter-spacing: -0.015em;
  }
  article h4 { font-size: 1.35rem; }
  article img {
    max-width: 100%;
    height: auto;
    border-radius: 16px;
    margin: 1.5rem 0;
  }
  article blockquote {
    margin: 3rem 0;
    padding: 0;
    border: none;
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.35;
    color: var(--fg);
    text-align: center;
  }
  article blockquote p { margin: 0; }
  article :not(pre) > code {
    background: var(--code-bg);
    padding: 0.15em 0.4em;
    border-radius: 6px;
    font-size: 0.88em;
  }
  article pre {
    padding: 1.25rem 1.5rem;
    border-radius: 14px;
    overflow-x: auto;
    font-size: 0.86rem;
    line-height: 1.6;
    margin: 1.75rem 0;
  }
  article ul, article ol { padding-left: 1.4rem; }
  article li { margin-bottom: 0.35rem; }
  article hr {
    border: none;
    border-top: 1px solid var(--border);
    margin: 3rem 0;
  }

  /* ——— footer ——— */
  footer {
    border-top: 1px solid var(--border);
  }
  .footer-inner {
    max-width: 46rem;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 3.5rem;
  }
  .footer-name {
    margin: 0 0 0.2rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    font-size: 0.95rem;
  }
  .footer-name span { color: var(--faint); font-weight: 400; }
  .footer-meta {
    margin: 0;
    color: var(--faint);
    font-size: 0.8rem;
  }
  .footer-meta a { color: var(--faint); }

  /* ——— mobile ——— */
  @media (max-width: 600px) {
    body { font-size: 16px; }
    .site-header nav { padding: 0.65rem 1.1rem; }
    .nav-right { gap: 0.9rem; }
    main { padding: 0 1.1rem 4rem; }
    article { font-size: 1rem; }
    article pre {
      padding: 0.9rem 1rem;
      border-radius: 10px;
      font-size: 0.8rem;
    }
    article blockquote {
      font-size: 1.25rem;
      margin: 2.25rem 0;
    }
    article img { border-radius: 10px; }
    .footer-inner { padding: 2rem 1.1rem 2.75rem; }
  }
</style>
